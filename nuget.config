<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Required when using Central Package Management with multiple package sources (e.g. nuget.org + Artifactory).
       Maps all packages to nuget.org so NU1507 is resolved. Add Artifactory mappings if you use private feeds. -->
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
